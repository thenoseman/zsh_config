#!/usr/bin/env zsh
# vim: set ft=zsh:

# Resolve the repo root relative to this script, regardless of cwd
script_dir=${0:A:h}

# Update async.zsh
curl -s -L "https://raw.githubusercontent.com/sindresorhus/pure/master/async.zsh" \
  -o "$script_dir/home/.zsh/modules/pure_prompt/async.zsh"

# Update iTerm2 shell integration
curl -s -L "https://iterm2.com/shell_integration/zsh" \
  -o "$script_dir/home/.zsh/config/iterm2_shell_integration.zsh"

# Update fzf-tab
if [[ ! -e ~/.zsh/modules/fzf-tab ]]; then
  git clone https://github.com/Aloxaf/fzf-tab ~/.zsh/modules/fzf-tab
else
  (cd ~/.zsh/modules/fzf-tab && git pull --rebase)
fi

# Compile fzf-tab native module
source ~/.zsh/modules/fzf-tab/fzf-tab.zsh
build-fzf-tab-module

# Compile zsh config and function files for faster sourcing
# (zsh automatically prefers .zwc when it is newer than the source file)
print "Compiling zsh files..."
for f in ~/.zsh/config/*(N.); do
  zcompile $f && print "  $f"
done
for f in ~/.zsh/zfunctions/*(N.); do
  zcompile -Uz $f && print "  $f"
done
