# mapfile / readarray polyfill for zsh (bash compatibility)
# Autoloaded on first call to mapfile.
#
# Implements a subset of bash's mapfile/readarray builtins:
#   mapfile [-n count] [-s count] [-t] [-u fd] [array]
#
# Reference: http://wiki.bash-hackers.org/commands/builtin/mapfile

mapfilehelp() {
  local -a lines=(
    "mapfile [-n count] [-s count] [-t] [-u fd] [array]"
    "readarray [-n count] [-s count] [-t] [-u fd] [array]"
    ""
    "Read lines from stdin into the indexed array variable ARRAY,"
    "or from file descriptor FD if -u is supplied. Default array: MAPFILE."
    ""
    "Options:"
    "  -n  Copy at most count lines (0 = all)"
    "  -s  Discard the first count lines"
    "  -t  No-op; accepted for drop-in bash compatibility"
    "  -u  Read from file descriptor FD instead of stdin"
  )
  printf '%s\n' "${lines[@]}"
}

mapfile() {
  local elementCount elementDiscard fileDescr arrIndex readOpt MAPFILE
  while getopts ":hn:s:tu:" flags; do
    case "${flags}" in
      (h) mapfilehelp; return 0 ;;
      (n) elementCount="${OPTARG}" ;;
      (s) elementDiscard="${OPTARG}" ;;
      (t) ;; # no-op, accepted for bash compatibility
      (u) fileDescr="${OPTARG}" ;;
      (*) mapfilehelp; return 1 ;;
    esac
  done
  shift "$(( OPTIND - 1 ))"

  # zsh arrays are 1-indexed
  arrIndex="${elementStart:-1}"
  readOpt="-A"

  local oldIFS="$IFS"
  IFS=$'\n'
  set -f   # disable globbing
  set +H   # disable history expansion on !

  if [[ -n "${elementCount}" ]] && (( elementCount > 0 )); then
    if [[ -n "${elementDiscard}" ]]; then
      for (( i = 0; i < elementDiscard; i++ )); do
        read -r
      done
    fi
    local i="${arrIndex}"
    while (( i < elementCount )); do
      read -r
      MAPFILE+=( "${REPLY}" )
      (( i++ ))
    done
  else
    read -d '' -r "${readOpt}" MAPFILE
    if [[ -n "${elementDiscard}" ]]; then
      MAPFILE=( "${MAPFILE[@]:$elementDiscard}" )
    fi
  fi <&"${fileDescr:-0}"

  if [[ -n "$1" ]]; then
    local element
    for element in "${MAPFILE[@]}"; do
      eval "$1+=( \"\${element}\" )"
    done
  fi

  IFS="${oldIFS}"
  set +f
  set -H
}

# readarray is an alias for mapfile in bash; mirror that here
alias readarray='mapfile'
